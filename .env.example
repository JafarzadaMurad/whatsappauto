PORT=3000
NODE_ENV=development

# Database (PostgreSQL) - port 5433 mappings from docker-compose
DATABASE_URL="postgresql://admin:secretpassword@localhost:5433/wazzup_db?schema=public"

# Redis - port 6380 mappings from docker-compose
REDIS_URL="redis://localhost:6380"
REDIS_HOST="localhost"
REDIS_PORT=6380

# JWT
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Socket.IO CORS
FRONTEND_URL="http://localhost:3001"
